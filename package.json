{
  "name": "ha-db-insights",
  "version": "1.0.0",
  "description": "Home Assistant add-on to inspect recorder database usage",
  "main": "dist/server.js",
  "scripts": {
    "generate-db": "node generate-sample-db.js",
    "build": "vite build --mode frontend && vite build --mode backend",
    "start": "node dist/server.js",
    "dev": "npm run build && node --watch dist/server.js",
    "watch:frontend": "vite build --watch --mode frontend",
    "watch:backend": "vite build --watch --mode backend",
    "test": "ts-node tests/smoke-tests.ts"
  },
  "keywords": [
    "homeassistant",
    "addon",
    "database"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",

    "ts-node": "^10.9.1",
    "typescript": "^5.1.3",
    "vite": "^5.4.0"
  }
}
